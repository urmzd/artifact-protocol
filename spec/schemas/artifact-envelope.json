{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aap.dev/schemas/artifact-envelope.json",
  "title": "Artifact Envelope",
  "description": "Wire-format message for the Agent-Artifact Protocol (AAP). Three envelope types: synthesize (in), edit (in), handle (out).",
  "type": "object",
  "required": ["protocol", "id", "version", "name", "operation", "content"],
  "properties": {
    "protocol": {
      "type": "string",
      "const": "aap/0.1",
      "description": "Protocol identifier and version"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique artifact identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonically increasing version number. For edit operations, the apply engine validates stored_version == version - 1"
    },
    "name": {
      "type": "string",
      "enum": ["synthesize", "edit", "handle"],
      "description": "Operation discriminator. Input: synthesize, edit. Output: handle."
    },
    "operation": {
      "type": "object",
      "required": ["direction"],
      "description": "Metadata about the action",
      "properties": {
        "direction": {
          "type": "string",
          "enum": ["input", "output"],
          "description": "Message direction: input (to the system) or output (from the system)"
        },
        "format": {
          "type": "string",
          "pattern": "^[a-z]+/[a-z0-9.+-]+$",
          "description": "MIME type of the artifact content"
        },
        "tokens_used": {
          "type": "integer",
          "minimum": 0,
          "description": "Actual content tokens consumed"
        },
        "checksum": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 hash of resolved content"
        },
        "state": {
          "type": "string",
          "enum": ["draft", "published", "archived"],
          "description": "Entity lifecycle state"
        }
      },
      "additionalProperties": true
    },
    "content": {
      "type": "array",
      "items": { "type": "object" },
      "description": "List of content objects — shape determined by name."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "name": { "const": "synthesize" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["body"],
              "properties": {
                "body": { "type": "string", "description": "Full artifact content" }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "edit" } } },
      "then": {
        "properties": {
          "content": {
            "items": { "$ref": "diff-operation.json" }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "handle" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["id", "version"],
              "properties": {
                "id": { "type": "string", "description": "Artifact ID" },
                "version": { "type": "integer", "minimum": 1, "description": "Artifact version" },
                "token_count": { "type": "integer", "minimum": 0, "description": "Approximate token count of the full artifact" },
                "state": { "type": "string", "enum": ["draft", "published", "archived"] },
                "content": { "type": "string", "description": "Optional artifact content (when requested)" }
              }
            }
          }
        }
      }
    }
  ]
}
