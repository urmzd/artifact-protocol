{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aap.dev/schemas/artifact-envelope.json",
  "title": "Artifact Envelope",
  "description": "Message format for the Agent-Artifact Protocol (AAP). Four envelope types: synthesize, edit, handle, handle_result.",
  "type": "object",
  "required": ["protocol", "id", "version", "name", "operation", "content"],
  "properties": {
    "protocol": {
      "type": "string",
      "const": "aap/0.1",
      "description": "Protocol identifier and version"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique artifact identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonically increasing version number. For edit operations, the apply engine validates stored_version == version - 1"
    },
    "name": {
      "type": "string",
      "enum": ["synthesize", "edit", "handle", "handle_result"],
      "description": "Operation discriminator — determines the shape of content items. Input: synthesize, edit. Output: handle, handle_result."
    },
    "operation": {
      "type": "object",
      "required": ["direction"],
      "description": "Metadata about the action",
      "properties": {
        "direction": {
          "type": "string",
          "enum": ["input", "output"],
          "description": "Message direction: input (to the system) or output (from the system)"
        },
        "format": {
          "type": "string",
          "pattern": "^[a-z]+/[a-z0-9.+-]+$",
          "description": "MIME type of the artifact content"
        },
        "encoding": {
          "type": "string",
          "default": "utf-8",
          "description": "Character encoding"
        },
        "token_budget": {
          "type": "object",
          "properties": {
            "max_tokens": {
              "type": "integer",
              "minimum": 1,
              "description": "Maximum content tokens"
            },
            "priority": {
              "type": "string",
              "enum": ["completeness", "brevity", "fidelity"],
              "description": "Budget priority hint"
            }
          },
          "description": "Token budget constraints"
        },
        "tokens_used": {
          "type": "integer",
          "minimum": 0,
          "description": "Actual content tokens consumed"
        },
        "checksum": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$",
          "description": "SHA-256 hash of resolved content"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 creation timestamp"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 update timestamp"
        },
        "state": {
          "type": "string",
          "enum": ["draft", "published", "archived"],
          "description": "Entity lifecycle state"
        },
        "state_changed_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last state transition"
        }
      },
      "additionalProperties": true
    },
    "content": {
      "type": "array",
      "items": { "type": "object" },
      "description": "List of content objects — shape determined by name."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "name": { "const": "synthesize" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["body"],
              "properties": {
                "body": { "type": "string", "description": "Full artifact content" },
                "targets": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id"],
                    "properties": {
                      "id": { "type": "string", "minLength": 1 },
                      "label": { "type": "string" }
                    }
                  },
                  "description": "Target definitions"
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "edit" } } },
      "then": {
        "properties": {
          "content": {
            "items": { "$ref": "diff-operation.json" }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "handle" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["sections"],
              "properties": {
                "sections": { "type": "array", "items": { "type": "string" }, "description": "Target IDs present in the artifact" },
                "token_count": { "type": "integer", "minimum": 0, "description": "Approximate token count of the full artifact" },
                "state": { "type": "string", "enum": ["draft", "published", "archived"] }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "name": { "const": "handle_result" } } },
      "then": {
        "properties": {
          "content": {
            "items": {
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["text", "edit", "error"],
                  "description": "Result type discriminator"
                }
              },
              "oneOf": [
                {
                  "properties": {
                    "type": { "const": "text" },
                    "body": { "type": "string", "description": "Free-form text response" }
                  },
                  "required": ["type", "body"]
                },
                {
                  "properties": {
                    "type": { "const": "edit" },
                    "status": { "type": "string", "enum": ["applied", "rejected", "partial", "conflict"] },
                    "changes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "target_id": { "type": "string" },
                          "description": { "type": "string" }
                        }
                      }
                    }
                  },
                  "required": ["type", "status", "changes"]
                },
                {
                  "properties": {
                    "type": { "const": "error" },
                    "code": { "type": "string" },
                    "message": { "type": "string" }
                  },
                  "required": ["type", "code", "message"]
                }
              ]
            }
          }
        }
      }
    }
  ]
}
